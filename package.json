{
  "name": "@derrickburns/genealogy-flow",
  "version": "0.1.0",
  "description": "GEDCOM particle-flow animation viewer plus offline tooling for parsing, geocoding, biography, and migration analysis.",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "license": "MIT",
  "homepage": "https://github.com/derrickburns/genealogy-flow",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/derrickburns/genealogy-flow.git"
  },
  "bugs": {
    "url": "https://github.com/derrickburns/genealogy-flow/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "bin": {
    "parse-gedcom": "dist/bin/parse-gedcom.js",
    "build-gazetteer": "dist/bin/build-gazetteer.js",
    "geocode": "dist/bin/geocode.js",
    "build-timeline": "dist/bin/build-timeline.js",
    "migrations": "dist/bin/migrations.js",
    "summarize-gedcom": "dist/bin/summarize.js",
    "biographer": "dist/bin/biographer.js",
    "audience": "dist/bin/audience.js"
  },
  "scripts": {
    "parse-gedcom": "tsx src/bin/parse-gedcom.ts",
    "build-gazetteer": "tsx src/bin/build-gazetteer.ts",
    "geocode": "tsx src/bin/geocode.ts",
    "build-timeline": "tsx src/bin/build-timeline.ts",
    "migrations": "tsx src/bin/migrations.ts",
    "summarize-gedcom": "tsx src/bin/summarize.ts",
    "biographer": "tsx src/bin/biographer.ts",
    "audience": "tsx src/bin/audience.ts",
    "typecheck": "tsc --noEmit",
    "typecheck:functions": "tsc -p tsconfig.functions.json",
    "test:ux": "node --test test/*.test.mjs",
    "build": "rm -rf dist && tsc -p tsconfig.build.json && node scripts/finalize-bins.mjs",
    "prepublishOnly": "pnpm run build",
    "seed-demo": "node scripts/seed-demo.mjs",
    "seed-demo:local": "node scripts/seed-demo.mjs --local",
    "smoke:demo:local": "node scripts/smoke-local-demo.mjs",
    "smoke:responsive": "node scripts/smoke-responsive-layout.mjs",
    "predeploy": "node scripts/prepare-public.mjs",
    "deploy": "pnpm run predeploy && pnpm exec wrangler pages deploy public",
    "dev": "pnpm run predeploy && pnpm exec wrangler pages dev public --persist-to .wrangler/state"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "adm-zip": "^0.5.16",
    "better-sqlite3": "^12.9.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@clerk/backend": "^1.0.0",
    "@cloudflare/workers-types": "^4.0.0",
    "@types/adm-zip": "^0.5.7",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "wrangler": "^4.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
